# Spotify Web API — Client Credentials flow (server-side only).
# Create an app at https://developer.spotify.com/dashboard to get these.
# Copy this file to `.env` for local `netlify dev`, or set them in
# Netlify → Site settings → Environment variables for production.
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here
